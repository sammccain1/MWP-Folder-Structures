# MWP Root — .gitignore

# ── Dev Artefacts (not template content) ─────────────────────────────────────

# Internal dev patches — not part of the publishable template
git_patches/

# Agent audit log — grows unboundedly every session; regenerated automatically
rules/audit.log
.gemini/rules/audit.log

# ── Sensitive / Auto-Generated ───────────────────────────────────────────────

# Knowledge graph — persistent agent memory (large; regenerated by MCP server)
.gemini/memory/knowledge.jsonl

# Local settings overrides (machine-specific paths, personal token paths)
.gemini/settings.local.json

# ── Security Scan Output ─────────────────────────────────────────────────────
# Produced by hooks/pen-test workflow — can contain target vulnerability info
docs/security/nikto-*.txt
docs/security/ffuf-*.json

# ── Node / Tool Artifacts ─────────────────────────────────────────────────────
node_modules/
.npm/

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

