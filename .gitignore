# .gemini gitignore

# ── Sensitive / Auto-Generated ───────────────────────────────────────────────

# Knowledge graph — contains persistent agent memory (can be large; regenerated by MCP server)
memory/knowledge.jsonl

# Audit log — grows unboundedly, not useful in git history
rules/audit.log

# Local settings overrides (e.g., personal token paths, machine-specific paths)
settings.local.json

# ── Security Scan Output ─────────────────────────────────────────────────────
# These are produced by hooks/pen-test workflow and can contain sensitive info
# about target vulnerabilities — store locally, not in git
../docs/security/nikto-*.txt
../docs/security/ffuf-*.json

# ── Node / Tool Artifacts ────────────────────────────────────────────────────
# If any MCP servers install locally inside .gemini
node_modules/
.npm/

# ── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo 
settings.json