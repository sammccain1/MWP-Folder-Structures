{
  "model": "gemini-2.5-pro",
  "generationConfig": {
    "temperature": 0.2,
    "thinkingConfig": {
      "thinkingBudget": 8000
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "name": "session-start",
            "type": "command",
            "command": ".gemini/hooks/session-start.sh",
            "description": "Load memory and print session context at startup",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "name": "secrets-check",
            "type": "command",
            "command": ".gemini/hooks/secrets-check.sh",
            "description": "Scan for leaked API keys or secrets before any tool runs",
            "timeout": 15000
          }
        ]
      },
      {
        "matcher": "run_shell_command|execute_bash",
        "hooks": [
          {
            "name": "pre-commit",
            "type": "command",
            "command": ".gemini/hooks/pre-commit.sh",
            "description": "Git snapshot and branch check before shell commands",
            "timeout": 15000
          }
        ]
      },
      {
        "matcher": "run_shell_command|execute_bash",
        "hooks": [
          {
            "name": "dependency-check",
            "type": "command",
            "command": ".gemini/hooks/dependency-check.sh",
            "description": "Scan npm and pip for known CVEs before package installs",
            "timeout": 30000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "name": "post-tool-audit",
            "type": "command",
            "command": ".gemini/hooks/post-tool.sh",
            "description": "Append structured audit entry after every tool call",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "write_file|replace_file|edit_file|create_file",
        "sequential": true,
        "hooks": [
          {
            "name": "lint-on-save",
            "type": "command",
            "command": ".gemini/hooks/lint-on-save.sh",
            "description": "Run appropriate linter after file writes",
            "timeout": 30000
          },
          {
            "name": "test-on-change",
            "type": "command",
            "command": ".gemini/hooks/test-on-change.sh",
            "description": "Run tests for changed source files",
            "timeout": 60000
          },
          {
            "name": "accessibility-check",
            "type": "command",
            "command": ".gemini/hooks/accessibility-check.sh",
            "description": "Run WCAG2AA check after UI file changes",
            "timeout": 30000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/sammccain/Projects",
        "/Users/sammccain/ProjectFolderBuilder"
      ]
    },
    "knowledge-graph": {
      "command": "npx",
      "args": ["-y", "@shaneholloman/mcp-knowledge-graph", "--memory-path", ".gemini/memory/knowledge.jsonl"]
    }
  }
}
