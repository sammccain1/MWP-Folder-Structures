# .env.example — copy to .env and fill in real values
# NEVER commit .env — this file is safe to commit (no real secrets)

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:8000

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-side only

# ── Database (direct connection) ─────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ── Auth ─────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── External APIs ─────────────────────────────────────────────
# Add your project-specific keys below this line
# MAPBOX_TOKEN=
# OPENAI_API_KEY=
# SPORTS_DATA_API_KEY=

# ── Python / FastAPI ──────────────────────────────────────────
SECRET_KEY=generate-with-python-secrets-token-hex-32
ALLOWED_ORIGINS=http://localhost:3000

# ── Vercel ────────────────────────────────────────────────────
# Set these in the Vercel dashboard — not here
# VERCEL_TOKEN=
